page {
  background-color: #f5f6fa;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  color: #333;
  font-size: 14px;
  line-height: 1.6;
}

.container {
  padding: 20rpx;
  padding-bottom: 120rpx;
}

/* 头部卡片 */
.header-card {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 20rpx;
  padding: 40rpx 30rpx;
  margin-bottom: 20rpx;
  color: white;
  text-align: center;
}

.header-card .title {
  font-size: 36rpx;
  font-weight: 700;
  margin-bottom: 10rpx;
}

.header-card .update-time {
  font-size: 24rpx;
  opacity: 0.8;
}

/* 分区标题 */
.section-title {
  color: #667eea;
  font-size: 30rpx;
  font-weight: 700;
  margin: 30rpx 0 15rpx 10rpx;
}

/* 订阅卡片 */
.sub-card {
  background: white;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 15rpx;
  border-left: 6rpx solid #667eea;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.08);
}

.sub-card.all-in-one {
  border-left-color: #48bb78;
  background: linear-gradient(135deg, #f0fff4 0%, #c6f6d5 100%);
}

.sub-card .card-header {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}

.sub-card .card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  flex: 1;
}

.sub-card .badge {
  background: #667eea;
  color: white;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  margin-left: 10rpx;
  font-weight: 600;
}

.sub-card .badge.allinone {
  background: #48bb78;
}

.sub-card .card-desc {
  font-size: 24rpx;
  color: #666;
  margin-bottom: 14rpx;
  line-height: 1.5;
}

.sub-card .tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-bottom: 14rpx;
}

.sub-card .tag {
  background: rgba(72,187,120,0.15);
  color: #2f855a;
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  font-weight: 600;
}

/* 订阅链接区域 */
.url-group {
  margin-bottom: 12rpx;
}

.url-label {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 6rpx;
  display: block;
}

.url-box {
  background: #f8f9fa;
  border: 2rpx solid #e9ecef;
  border-radius: 10rpx;
  padding: 12rpx 16rpx;
  font-size: 22rpx;
  color: #667eea;
  word-break: break-all;
  user-select: all;
}

.url-box:active {
  background: #e7f0ff;
  border-color: #667eea;
}

/* 按钮 */
.btn-copy {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  border: none;
  border-radius: 12rpx;
  padding: 14rpx 32rpx;
  font-size: 28rpx;
  font-weight: 600;
  text-align: center;
  margin-top: 10rpx;
}

.btn-copy:active {
  opacity: 0.85;
}

/* Tab 栏 */
.tab-bar {
  display: flex;
  border-bottom: 2rpx solid rgba(255,255,255,0.3);
  margin-bottom: 20rpx;
}

.tab-item {
  padding: 12rpx 24rpx;
  color: rgba(255,255,255,0.7);
  font-weight: 500;
  border-bottom: 4rpx solid transparent;
  margin-bottom: -2rpx;
  transition: all 0.2s;
}

.tab-item.active {
  color: white;
  border-bottom-color: white;
  font-weight: 600;
}

/* 教程步骤 */
.step {
  display: flex;
  margin-bottom: 20rpx;
  align-items: flex-start;
}

.step-num {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 700;
  font-size: 24rpx;
  flex-shrink: 0;
  margin-right: 16rpx;
  margin-top: 4rpx;
}

.step-content {
  flex: 1;
}

.step-content .step-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 6rpx;
}

.step-content .step-desc {
  font-size: 24rpx;
  color: #666;
  line-height: 1.6;
}

/* 表单 */
.form-group {
  margin-bottom: 24rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 10rpx;
}

.form-input {
  width: 100%;
  min-height: 80rpx;
  padding: 16rpx 20rpx;
  border: 2rpx solid #e9ecef;
  border-radius: 12rpx;
  font-size: 28rpx;
  background: #f8f9fa;
  box-sizing: border-box;
  line-height: 48rpx;
}

.form-tip {
  font-size: 22rpx;
  color: #999;
  margin-top: 6rpx;
  display: block;
}

.checkbox-item {
  display: flex;
  align-items: center;
  padding: 12rpx 0;
  font-size: 28rpx;
}

.checkbox-item checkbox {
  margin-right: 10rpx;
}

.radio-group {
  display: flex;
  gap: 30rpx;
  align-items: center;
}

.radio-item {
  display: flex;
  align-items: center;
  font-size: 26rpx;
}

.radio-item radio {
  margin-right: 6rpx;
}

/* CF Workers 入口提示 */
.workers-banner {
  background: #fff3cd;
  border: 2rpx solid #ffc107;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  margin-bottom: 20rpx;
  font-size: 24rpx;
  color: #856404;
}

/* 结果卡片 */
.result-card {
  background: linear-gradient(135deg, #f0fff4 0%, #c6f6d5 100%);
  border-radius: 12rpx;
  padding: 20rpx;
  border-left: 6rpx solid #48bb78;
  margin-top: 20rpx;
}

.result-card .result-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #2f855a;
  margin-bottom: 10rpx;
}

/* 底部导航 */
.footer {
  text-align: center;
  font-size: 22rpx;
  color: #999;
  margin-top: 30rpx;
  padding-bottom: 20rpx;
}

.footer .link {
  color: #667eea;
  text-decoration: underline;
}
