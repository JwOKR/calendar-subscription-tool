<view class="container">
  <!-- 头部 -->
  <view class="header-card">
    <view class="title">📅 日历订阅工具</view>
    <view class="update-time">⚡ 静态文件，每天自动更新</view>
    <view class="update-time">📅 覆盖 2021 ~ 2028 年</view>
  </view>

  <!-- 图标版本切换 -->
  <view class="mode-switch">
    <view class="switch-label">订阅版本：</view>
    <view class="switch-track {{iconMode === 'noicon' ? 'track-noicon' : 'track-icon'}}" bindtap="switchIconMode">
      <view class="switch-thumb {{iconMode === 'noicon' ? 'thumb-left' : 'thumb-right'}}">
        {{iconMode === 'noicon' ? '📝 无图标' : '🎨 带图标'}}
      </view>
    </view>
  </view>

  <!-- CF Workers 入口 -->
  <view class="workers-banner" bindtap="goCustomize">
    🚀 想要更多定制选项？前往定制页 →
  </view>

  <!-- 订阅列表：动态渲染 -->
  <block wx:for="{{subscriptions}}" wx:key="id">
    <!-- 分区标题：仅该 section 首个卡片显示 -->
    <view wx:if="{{sectionMeta[index] && sectionMeta[index].show}}" class="section-title">
      {{sectionMeta[index].title}}
    </view>

    <sub-card
      name="{{item.name}}"
      icon="{{item.icon}}"
      desc="{{item.desc}}"
      badge="{{item.badge}}"
      badgeType="{{item.badgeType}}"
      sources="{{item.sources}}"
      tags="{{item.tags}}"
      iconMode="{{iconMode}}"
    ></sub-card>
  </block>

  <!-- 使用教程入口 -->
  <view class="section-title">📱 使用教程</view>
  <view class="tutorial-card" bindtap="goTutorial">
    <view class="tutorial-title">📱 如何订阅日历？</view>
    <view class="tutorial-desc">iOS / Android / Outlook 订阅方法 →</view>
  </view>

  <!-- 底部 -->
  <view class="footer">
    <text>⚡ 静态文件 | </text>
    <text class="link" bindtap="goGitHub">GitHub 仓库</text>
  </view>
</view>
