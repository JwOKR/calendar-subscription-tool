<view class="sub-card {{badgeType === 'allinone' ? 'all-in-one' : ''}}">
  <view class="card-header">
    <view class="card-title">{{icon}} {{name}}</view>
    <view wx:if="{{badge}}" class="badge {{badgeType === 'allinone' ? 'allinone' : ''}}">{{badge}}</view>
  </view>
  <view class="card-desc">{{desc}}</view>
  <view wx:if="{{tags && tags.length > 0}}" class="tags">
    <view wx:for="{{tags}}" wx:key="*this" class="tag">{{item}}</view>
  </view>
  <!-- 只显示一个版本的链接 -->
  <view class="url-group">
    <view class="url-label">{{linkLabel}}</view>
    <view class="url-box" bindtap="onCopyUrl">
      {{displayUrl}}
    </view>
  </view>
</view>
